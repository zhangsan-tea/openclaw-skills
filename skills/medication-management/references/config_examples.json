{
  "_comment": "药品管理系统配置文件示例",
  "_version": "1.0",
  "_updated": "2026-03-22",
  
  "reminder_settings": {
    "_comment": "提醒设置",
    "check_frequency": "weekly",
    "check_day": "sunday",
    "check_time": "09:00",
    "advance_days": [7, 0],
    "enabled": true
  },
  
  "storage": {
    "_comment": "存储设置",
    "csv_path": "medications/medications.csv",
    "backup_enabled": true,
    "backup_frequency": "daily",
    "backup_retention_days": 30,
    "photos_dir": "medications/photos",
    "cloud_backup": {
      "enabled": true,
      "provider": "google_drive",
      "folder": "medications_backup"
    }
  },
  
  "recognition": {
    "_comment": "识别设置（可选功能）",
    "enable_barcode": false,
    "enable_photo_ocr": false,
    "ocr_provider": "google_vision",
    "manual_fallback": true,
    "photo_pair_mode": true
  },
  
  "models": {
    "_comment": "模型设置（多模型切换）",
    "primary": "coding-plan/glm-5",
    "fallback": [
      "ollama/qwen3:8b",
      "coding-plan/qwen3-max-2026-01-23"
    ],
    "timeout_seconds": 60,
    "max_retries": 3,
    "auto_switch": true
  },
  
  "notifications": {
    "_comment": "通知设置",
    "channel": "telegram",
    "user_id": "8051279955",
    "enable_buttons": true,
    "reminder_interval_hours": 24,
    "max_reminders": 3
  },
  
  "error_handling": {
    "_comment": "错误处理设置",
    "auto_retry": true,
    "retry_delay_seconds": 30,
    "notify_on_error": true,
    "fallback_to_manual": true
  },
  
  "multi_user": {
    "_comment": "多用户设置（开发中）",
    "enabled": false,
    "version": "2.0"
  }
}
